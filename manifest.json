{
  "$schema": "https://json.schemastore.org/chrome-manifest",
  "name": "Em dash highlighter",
  "version": "0.0.1",
  "manifest_version": 3,
  "description": "It does what it says on the tin.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scan.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}
